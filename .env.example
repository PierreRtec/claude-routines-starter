# claude-routines-starter, exemple de configuration
# Copie ce fichier en .env et remplis les valeurs.
# NE COMMIT JAMAIS .env (déjà dans .gitignore).

# PAT GitHub fine-grained avec scope Actions:write sur ton fork de claude-dispatch.
# Crée-le sur https://github.com/settings/personal-access-tokens/new
GITHUB_PAT_ROUTINES=

# Repo claude-dispatch que tu as créé (format: owner/repo)
DISPATCH_REPO=

# URL du webhook n8n mail-gateway (depuis le node Webhook après import du workflow)
N8N_WEBHOOK=

# Adresse mail destinataire par défaut
MAIL_TO=
